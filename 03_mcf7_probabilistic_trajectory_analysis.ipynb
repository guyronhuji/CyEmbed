    "# === Helpers ===\n",
    "required_files = [\n",
    "    \"config.json\",\n",
    "    \"summary_metrics.json\",\n",
    "    \"history.csv\",\n",
    "    \"X_observed.npy\",\n",
    "    \"X_hat.npy\",\n",
    "    \"W.npy\",\n",
    "    \"A_hat.npy\",\n",
    "    \"marker_names.csv\",\n",
    "    \"cell_ids.csv\",\n",
    "]\n",
    "\n",
    "def _iter_run_dirs(root: Path):\n",
    "    if not root.exists():\n",
    "        return\n",
    "    if any((root / f).exists() for f in required_files):\n",
    "        yield root\n",
    "    for p in sorted(root.rglob(\"run_*\")):\n",
    "        if p.is_dir():\n",
    "            yield p\n",
    "\n",
    "def discover_runs(candidates: list[Path]) -> pd.DataFrame:\n",
    "    rows = []\n",
    "    seen = set()\n",
    "    for root in candidates:\n",
    "        for run_dir in _iter_run_dirs(root):\n",
    "            rp = str(run_dir.resolve())\n",
    "            if rp in seen:\n",
    "                continue\n",
    "            seen.add(rp)\n",
    "            if not all((run_dir / f).exists() for f in required_files):\n",
    "                continue\n",
    "            try:\n",
    "                cfg = json.loads((run_dir / \"config.json\").read_text(encoding=\"utf-8\"))\n",
    "                sm = json.loads((run_dir / \"summary_metrics.json\").read_text(encoding=\"utf-8\"))\n",
    "                val = sm.get(\"val\", {})\n",
    "                val_recon = float(sm.get(\"best_val_recon\", sm.get(\"final_val_recon\", np.nan)))\n",
    "                rows.append({\n",
    "                    \"run_id\": sm.get(\"run_id\", run_dir.name),\n",
    "                    \"run_dir\": rp,\n",
    "                    \"mtime\": run_dir.stat().st_mtime,\n",
    "                    \"model_type\": str(cfg.get(\"model_type\", \"deterministic\")).lower(),\n",
    "                    \"decoder_type\": cfg.get(\"decoder_type\"),\n",
    "                    \"K\": int(cfg.get(\"K\", -1)),\n",
    "                    \"d\": cfg.get(\"d\"),\n",
    "                    \"tau\": cfg.get(\"tau\"),\n",
    "                    \"val_recon\": val_recon,\n",
    "                    \"dead_archetypes\": float(val.get(\"dead_archetypes_lt_1pct\", np.nan)),\n",
    "                    \"usage_std\": float(val.get(\"usage_std\", np.nan)),\n",
    "                    \"mean_entropy\": float(val.get(\"mean_weight_entropy\", np.nan)),\n",
    "                    \"purity_gt_08\": float(val.get(\"dominant_frac_gt_0_8\", np.nan)),\n",
    "                })\n",
    "            except Exception as exc:\n",
    "                print(f\"Skipping unreadable run: {run_dir} ({exc})\")\n",
    "    if not rows:\n",
    "        return pd.DataFrame()\n",
    "    return pd.DataFrame(rows).sort_values(\"mtime\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "def _to_k_list(value):\n",
    "    if value is None:\n",
    "        return None\n",
    "    if isinstance(value, (list, tuple, set, np.ndarray)):\n",
    "        return [int(v) for v in value]\n",
    "    return [int(value)]\n",
    "\n",
    "def finite_or_default(x: np.ndarray, default: float = 0.0) -> np.ndarray:\n",
    "    x = np.asarray(x, dtype=np.float64)\n",
    "    finite = np.isfinite(x)\n",
    "    if not finite.any():\n",
    "        return np.full_like(x, float(default), dtype=np.float64)\n",
    "    out = x.copy()\n",
    "    fill = float(np.median(x[finite]))\n",
    "    out[~finite] = fill\n",
    "    return out\n",
    "\n",
    "def zscore_robust(x: np.ndarray) -> np.ndarray:\n",
    "    x = finite_or_default(x, default=0.0)\n",
    "    med = np.median(x)\n",
    "    mad = np.median(np.abs(x - med))\n",
    "    scale = max(1.4826 * mad, 1e-8)\n",
    "    return (x - med) / scale\n",
    "\n",
    "def stable_softmax(logits: np.ndarray, axis: int = 1) -> np.ndarray:\n",
    "    x = logits - np.max(logits, axis=axis, keepdims=True)\n",
    "    ex = np.exp(x)\n",
    "    return ex / np.clip(ex.sum(axis=axis, keepdims=True), 1e-12, None)\n",
    "\n",
    "def percentile_limits(x: np.ndarray, q_low: float = 0.01, q_high: float = 0.99):\n",
    "    vals = np.asarray(x, dtype=np.float64)\n",
    "    vals = vals[np.isfinite(vals)]\n",
    "    if vals.size == 0:\n",
    "        return None, None\n",
    "    lo = float(np.quantile(vals, q_low))\n",
    "    hi = float(np.quantile(vals, q_high))\n",
    "    if not np.isfinite(lo) or not np.isfinite(hi) or hi <= lo:\n",
    "        lo = float(np.min(vals))\n",
    "        hi = float(np.max(vals))\n",
    "        if hi <= lo:\n",
    "            return None, None\n",
    "    return lo, hi\n",
    "\n",
    "def align_archetypes(a_ref: np.ndarray, a_cmp: np.ndarray):\n",
    "    # Greedy cosine-similarity matching (works well when K is modest).\n",
    "    eps = 1e-8\n",
    "    xr = a_ref / np.clip(np.linalg.norm(a_ref, axis=1, keepdims=True), eps, None)\n",
    "    xc = a_cmp / np.clip(np.linalg.norm(a_cmp, axis=1, keepdims=True), eps, None)\n",
    "    sim = xr @ xc.T\n",
    "    k = sim.shape[0]\n",
    "    used_r = set()\n",
    "    used_c = set()\n",
    "    pairs = []\n",
    "    flat = [(sim[i, j], i, j) for i in range(k) for j in range(k)]\n",
    "    for _, i, j in sorted(flat, key=lambda t: t[0], reverse=True):\n",
    "        if i in used_r or j in used_c:\n",
    "            continue\n",
    "        used_r.add(i)\n",
    "        used_c.add(j)\n",
    "        pairs.append((i, j))\n",
    "        if len(pairs) == k:\n",
    "            break\n",
    "    pairs = sorted(pairs, key=lambda t: t[0])\n",
    "    perm = [j for _, j in pairs]\n",
    "    return np.array(perm, dtype=int), sim\n",
    "\n",
    "def build_knn_graph(weights: np.ndarray, k: int = 15, max_cells: int = 8000, seed: int = 0, show_progress: bool = True):\n",
    "    rng = np.random.default_rng(seed)\n",
    "    n = weights.shape[0]\n",
    "    if show_progress:\n",
    "        print(f'kNN graph input cells: {n}')\n",
    "    if n > max_cells:\n",
    "        keep = np.sort(rng.choice(n, size=max_cells, replace=False))\n",
    "    else:\n",
    "        keep = np.arange(n)\n",
    "    if show_progress:\n",
    "        print(f'Using {len(keep)} cells for graph construction')\n",
    "    w = weights[keep]\n",
    "    if show_progress:\n",
    "        print('Computing pairwise distances...')\n",
    "    diff = w[:, None, :] - w[None, :, :]\n",
    "    dist = np.sqrt(np.sum(diff * diff, axis=2))\n",
    "    np.fill_diagonal(dist, np.inf)\n",
    "    if show_progress:\n",
    "        print('Selecting nearest neighbors...')\n",
    "    nn = np.argsort(dist, axis=1)[:, :k]\n",
    "    graph = [dict() for _ in range(w.shape[0])]\n",
    "    node_iter = range(w.shape[0])\n",
    "    if show_progress and tqdm is not None:\n",
    "        node_iter = tqdm(node_iter, total=w.shape[0], desc='kNN graph edges')\n",
    "    elif show_progress and tqdm is None:\n",
    "        print('tqdm not available; building kNN graph without progress bar.')\n",
    "    for i in node_iter:\n",
    "        for j in nn[i]:\n",
    "            d = float(dist[i, j])\n",
    "            graph[i][int(j)] = d\n",
    "            graph[int(j)][i] = min(graph[int(j)].get(i, np.inf), d)\n",
    "    return keep, graph\n",
    "\n",
    "def dijkstra_multi_source(graph, sources, show_progress: bool = True):\n",
    "    n = len(graph)\n",
    "    d = np.full(n, np.inf, dtype=np.float64)\n",
    "    pq = []\n",
    "    for s in sources:\n",
    "        d[s] = 0.0\n",
    "        heapq.heappush(pq, (0.0, int(s)))\n",
    "    pbar = None\n",
    "    visited = np.zeros(n, dtype=bool)\n",
    "    if show_progress and tqdm is not None:\n",
    "        pbar = tqdm(total=n, desc='Dijkstra visited nodes')\n",
    "    elif show_progress and tqdm is None:\n",
    "        print('tqdm not available; running Dijkstra without progress bar.')\n",
    "    while pq:\n",
    "        cd, u = heapq.heappop(pq)\n",
    "        if cd > d[u]:\n",
    "            continue\n",
    "        if not visited[u]:\n",
    "            visited[u] = True\n",
    "            if pbar is not None:\n",
    "                pbar.update(1)\n",
    "        for v, w in graph[u].items():\n",
    "            nd = cd + w\n",
    "            if nd < d[v]:\n",
    "                d[v] = nd\n",
    "                heapq.heappush(pq, (nd, v))\n",
    "    if pbar is not None:\n",
    "        pbar.close()\n",
    "    return d\n",
    "\n",
    "def corridor_table(W: np.ndarray, entropy: np.ndarray, uncertainty: np.ndarray, residual_norm: np.ndarray, pair_mass_thr: float, other_mass_thr: float, show_progress: bool = True):\n",
    "    K = W.shape[1]\n",
    "    rows = []\n",
    "    top2 = np.argsort(W, axis=1)[:, -2:]\n",
    "    pair_list = list(combinations(range(K), 2))\n",
    "    pair_iter = pair_list\n",
    "    if show_progress and tqdm is not None:\n",
    "        pair_iter = tqdm(pair_list, total=len(pair_list), desc='Corridor pairs')\n",
    "    elif show_progress and tqdm is None:\n",
    "        print('tqdm not available; running corridor analysis without progress bar.')\n",
    "    for a, b in pair_iter:\n",
    "        pair_mass = W[:, a] + W[:, b]\n",
    "        other_mass = 1.0 - pair_mass\n",
    "        is_top2 = np.logical_or(np.logical_and(top2[:, 0] == a, top2[:, 1] == b), np.logical_and(top2[:, 0] == b, top2[:, 1] == a))\n",
    "        mask = is_top2 & (pair_mass >= pair_mass_thr) & (other_mass <= other_mass_thr)\n",
    "        n = int(mask.sum())\n",
    "        if n == 0:\n",
    "            rows.append({\"a\": a, \"b\": b, \"n_cells\": 0, \"mean_entropy\": np.nan, \"mean_uncertainty\": np.nan, \"mean_residual_norm\": np.nan, \"has_cells\": False})\n",
    "            continue\n",
    "        residual_slice = residual_norm[mask]\n",
    "        mean_residual = float(np.nanmean(residual_slice)) if np.isfinite(residual_slice).any() else np.nan\n",
    "        rows.append({\n",
    "            \"a\": a,\n",
    "            \"b\": b,\n",
    "            \"n_cells\": n,\n",
    "            \"mean_entropy\": float(np.nanmean(entropy[mask])),\n",
    "            \"mean_uncertainty\": float(np.nanmean(uncertainty[mask])),\n",
    "            \"mean_residual_norm\": mean_residual,\n",
    "            \"has_cells\": True,\n",
    "        })\n",
    "    return pd.DataFrame(rows).sort_values(\"n_cells\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "def pair_progress(W: np.ndarray, a: int, b: int):\n",
    "    return W[:, b] / np.clip(W[:, a] + W[:, b], 1e-8, None)\n"
    "\n",
    "def corridor_mask_for_pair(W: np.ndarray, a: int, b: int, pair_mass_thr: float, other_mass_thr: float) -> np.ndarray:\n",
    "    top2 = np.argsort(W, axis=1)[:, -2:]\n",
    "    pair_mass = W[:, a] + W[:, b]\n",
    "    other_mass = 1.0 - pair_mass\n",
    "    is_top2 = np.logical_or(\n",
    "        np.logical_and(top2[:, 0] == a, top2[:, 1] == b),\n",
    "        np.logical_and(top2[:, 0] == b, top2[:, 1] == a),\n",
    "    )\n",
    "    return is_top2 & (pair_mass >= pair_mass_thr) & (other_mass <= other_mass_thr)\n",
    "\n",
    "def binned_curve(x: np.ndarray, y: np.ndarray, n_bins: int = 25, min_count: int = 30) -> pd.DataFrame:\n",
    "    x = np.asarray(x, dtype=np.float64)\n",
    "    y = np.asarray(y, dtype=np.float64)\n",
    "    valid = np.isfinite(x) & np.isfinite(y)\n",
    "    if valid.sum() == 0:\n",
    "        return pd.DataFrame(columns=['bin_left','bin_right','bin_center','count','mean','sem'])\n",
    "    xv = x[valid]\n",
    "    yv = y[valid]\n",
    "    bins = np.linspace(0.0, 1.0, int(n_bins) + 1)\n",
    "    idx = np.digitize(xv, bins) - 1\n",
    "    rows = []\n",
    "    for i in range(len(bins) - 1):\n",
    "        m = idx == i\n",
    "        n = int(m.sum())\n",
    "        if n < int(min_count):\n",
    "            continue\n",
    "        yi = yv[m]\n",
    "        rows.append({\n",
    "            'bin_left': float(bins[i]),\n",
    "            'bin_right': float(bins[i + 1]),\n",
    "            'bin_center': float(0.5 * (bins[i] + bins[i + 1])),\n",
    "            'count': n,\n",
    "            'mean': float(np.mean(yi)),\n",
    "            'sem': float(np.std(yi, ddof=1) / np.sqrt(n)) if n > 1 else 0.0,\n",
    "        })\n",
    "    return pd.DataFrame(rows)\n"
   ]
  },
