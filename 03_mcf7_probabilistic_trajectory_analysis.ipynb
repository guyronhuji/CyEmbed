   "source": [
    "# === Build per-cell trajectory table for primary run ===\n",
    "def prepare_run(run: dict, label: str):\n",
    "    X = run['X_observed']\n",
    "    A_hat = run['A_hat']\n",
    "    cell_ids = run['cell_ids']\n",
    "    cfg = run['config']\n",
    "\n",
    "    W_sample = run.get('W_sample', run.get('W'))\n",
    "    if run.get('W_mean') is not None:\n",
    "        W_mean = run['W_mean']\n",
    "    elif run.get('mu_w') is not None:\n",
    "        W_mean = posterior_mean_weights(run['mu_w'], tau=float(cfg.get('tau', 1.0)))\n",
    "    else:\n",
    "        W_mean = None\n",
    "    W = W_mean if W_mean is not None else W_sample\n",
    "\n",
    "    dom_df = dominant_assignments(W, cell_ids=cell_ids)\n",
    "    top2 = np.sort(W, axis=1)[:, -2:]\n",
    "    top12_margin = top2[:, 1] - top2[:, 0]\n",
    "    top2_mass = top2.sum(axis=1)\n",
    "    eff_support = np.exp(dom_df['entropy'].to_numpy())\n",
    "\n",
    "    if run.get('logvar_w') is not None:\n",
    "        uncertainty = np.exp(np.clip(run['logvar_w'], -20, 20)).mean(axis=1)\n",
    "    else:\n",
    "        uncertainty = np.full(W.shape[0], np.nan, dtype=np.float64)\n",
    "\n",
    "    if run.get('R') is not None:\n",
    "        rnorm = residual_norms(run['R'])\n",
    "    elif run.get('R_sample') is not None:\n",
    "        rnorm = residual_norms(run['R_sample'])\n",
    "    else:\n",
    "        rnorm = np.full(W.shape[0], np.nan, dtype=np.float64)\n",
    "\n",
    "    table = pd.DataFrame({\n",
    "        'cell_id': np.asarray(cell_ids),\n",
    "        'dominant_archetype': dom_df['dominant_archetype'].to_numpy(),\n",
    "        'dominant_weight': dom_df['dominant_weight'].to_numpy(),\n",
    "        'entropy': dom_df['entropy'].to_numpy(),\n",
    "        'top12_margin': top12_margin,\n",
    "        'top2_mass': top2_mass,\n",
    "        'effective_support': eff_support,\n",
    "        'uncertainty': uncertainty,\n",
    "        'residual_norm': rnorm,\n",
    "    })\n",
    "\n",
    "    uncertainty_values = table['uncertainty'].to_numpy()\n",
    "    residual_values = table['residual_norm'].to_numpy()\n",
    "    uncertainty_term = zscore_robust(uncertainty_values) if np.isfinite(uncertainty_values).any() else np.zeros(len(table), dtype=np.float64)\n",
    "    residual_term = zscore_robust(residual_values) if np.isfinite(residual_values).any() else np.zeros(len(table), dtype=np.float64)\n",
    "    stability_raw = (\n",
    "        + zscore_robust(table['dominant_weight'].to_numpy())\n",
    "        + zscore_robust(table['top12_margin'].to_numpy())\n",
    "        - zscore_robust(table['entropy'].to_numpy())\n",
    "        - uncertainty_term\n",
    "        - residual_term\n",
    "    )\n",
    "    table['stability_score_raw'] = stability_raw\n",
    "    s_lo, s_hi = percentile_limits(stability_raw, q_low=stability_outlier_q_low, q_high=stability_outlier_q_high)\n",
    "    if remove_stability_outliers and s_lo is not None and s_hi is not None:\n",
    "        stability_outlier = (stability_raw < s_lo) | (stability_raw > s_hi)\n",
    "        stability = stability_raw.copy()\n",
    "        stability[stability_outlier] = np.nan\n",
    "        print(f'[{label}] Removed stability outliers: {int(stability_outlier.sum())}/{len(stability_outlier)} using q=({stability_outlier_q_low:.3f}, {stability_outlier_q_high:.3f})')\n",
    "    else:\n",
    "        stability_outlier = np.zeros(len(stability_raw), dtype=bool)\n",
    "        stability = stability_raw\n",
    "    table['stability_outlier'] = stability_outlier\n",
    "    table['stability_score'] = stability\n",
    "    table['plasticity_score'] = -stability\n",
    "\n",
    "    pca = pca_projection(W, n_components=2)\n",
    "    umap = umap_projection(W, n_neighbors=min(umap_n_neighbors, max(2, W.shape[0] - 1)), min_dist=umap_min_dist, random_state=7)\n",
    "\n",
    "    out = {\n",
    "        'label': label,\n",
    "        'X': X,\n",
    "        'A_hat': A_hat,\n",
    "        'W': W,\n",
    "        'W_mean': W_mean,\n",
    "        'W_sample': W_sample,\n",
    "        'table': table,\n",
    "        'pca': pca,\n",
    "        'umap': umap,\n",
    "        'sample_ids': run.get('sample_ids'),\n",
    "        'cluster_ids': run.get('cluster_ids'),\n",
    "        'config': cfg,\n",
    "    }\n",
    "    return out\n",
    "\n",
    "primary = prepare_run(run_primary, 'primary')\n",
    "secondary = prepare_run(run_secondary, 'secondary') if run_secondary is not None else None\n",
    "\n",
    "primary['table'].to_csv(ANALYSIS_OUTDIR / 'primary_per_cell_trajectory_metrics.csv', index=False)\n",
    "display(primary['table'].head())\n",
    "\n",
    "fig, axes = plt.subplots(2, 3, figsize=(14, 7))\n",
    "sns.histplot(primary['table']['dominant_weight'], bins=60, ax=axes[0,0], color='tab:blue'); axes[0,0].set_title('Dominant weight')\n",
    "sns.histplot(primary['table']['entropy'], bins=60, ax=axes[0,1], color='tab:orange'); axes[0,1].set_title('Entropy')\n",
    "sns.histplot(primary['table']['top12_margin'], bins=60, ax=axes[0,2], color='tab:green'); axes[0,2].set_title('Top1-Top2 margin')\n",
    "unc_plot = primary['table']['uncertainty'].dropna()\n",
    "if len(unc_plot) > 0:\n",
    "    sns.histplot(unc_plot, bins=60, ax=axes[1,0], color='tab:purple')\n",
    "else:\n",
    "    axes[1,0].text(0.5, 0.5, 'No uncertainty data', ha='center', va='center', transform=axes[1,0].transAxes)\n",
    "axes[1,0].set_title('Posterior uncertainty')\n",
    "res_plot = primary['table']['residual_norm'].dropna()\n",
    "if len(res_plot) > 0:\n",
    "    sns.histplot(res_plot, bins=60, ax=axes[1,1], color='tab:red')\n",
    "else:\n",
    "    axes[1,1].text(0.5, 0.5, 'No residual latent in run', ha='center', va='center', transform=axes[1,1].transAxes)\n",
    "axes[1,1].set_title('Residual norm')\n",
    "stab_plot = primary['table']['stability_score'].dropna()\n",
    "if len(stab_plot) > 0:\n",
    "    sns.histplot(stab_plot, bins=60, ax=axes[1,2], color='tab:gray')\n",
    "else:\n",
    "    axes[1,2].text(0.5, 0.5, 'No stability score available', ha='center', va='center', transform=axes[1,2].transAxes)\n",
    "axes[1,2].set_title('Stability score')\n",
    "plt.tight_layout()\n",
    "\n",
    "if primary['umap'] is not None:\n",
    "    fig, axes = plt.subplots(1, 4, figsize=(18, 4))\n",
    "    axes[0].scatter(primary['umap'][:,0], primary['umap'][:,1], c=primary['table']['dominant_archetype'], s=3, cmap='tab20', linewidths=0)\n",
    "    axes[0].set_title('UMAP: dominant archetype')\n",
    "    for ax, col, title, cmap in [\n",
    "        (axes[1], 'entropy', 'UMAP: entropy', 'magma'),\n",
    "        (axes[2], 'top12_margin', 'UMAP: top1-top2 margin', 'viridis'),\n",
    "        (axes[3], 'stability_score', 'UMAP: stability score', 'coolwarm'),\n",
    "    ]:\n",
    "        values = primary['table'][col].to_numpy()\n",
    "        vmin, vmax = percentile_limits(values, q_low=color_clip_q_low, q_high=color_clip_q_high)\n",
    "        sc = ax.scatter(primary['umap'][:,0], primary['umap'][:,1], c=values, s=3, cmap=cmap, linewidths=0, vmin=vmin, vmax=vmax)\n",
    "        ax.set_title(title)\n",
    "        plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)\n",
    "    plt.tight_layout()\n",
    "else:\n",
    "    print('umap-learn unavailable: using PCA only for state-space visualization.')\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(14, 4))\n",
    "axes[0].scatter(primary['pca'][:,0], primary['pca'][:,1], c=primary['table']['dominant_archetype'], s=3, cmap='tab20', linewidths=0)\n",
    "axes[0].set_title('PCA: dominant archetype')\n",
    "for ax, col, title in [(axes[1], 'entropy', 'PCA: entropy'), (axes[2], 'stability_score', 'PCA: stability')]:\n",
    "    values = primary['table'][col].to_numpy()\n",
    "    vmin, vmax = percentile_limits(values, q_low=color_clip_q_low, q_high=color_clip_q_high)\n",
    "    sc = ax.scatter(primary['pca'][:,0], primary['pca'][:,1], c=values, s=3, cmap='magma', linewidths=0, vmin=vmin, vmax=vmax)\n",
    "    ax.set_title(title)\n",
    "    plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)\n",
    "plt.tight_layout()\n"
   ]
  },
