    "# === Group summaries + robustness across selected runs ===\n",
    "def summarize_groups(run_obj, prefix: str):\n",
    "    W = run_obj['W']\n",
    "    out = {}\n",
    "    if run_obj['sample_ids'] is not None:\n",
    "        s = summarize_by_group(W, run_obj['sample_ids'], group_name='sample')\n",
    "        s['mean_weights'].to_csv(ANALYSIS_OUTDIR / f'{prefix}_sample_mean_weights.csv', index=False)\n",
    "        s['dominant_fractions'].to_csv(ANALYSIS_OUTDIR / f'{prefix}_sample_dominant_fractions.csv', index=False)\n",
    "        out['sample'] = s\n",
    "    if run_obj['cluster_ids'] is not None:\n",
    "        c = summarize_by_group(W, run_obj['cluster_ids'], group_name='cluster')\n",
    "        c['mean_weights'].to_csv(ANALYSIS_OUTDIR / f'{prefix}_cluster_mean_weights.csv', index=False)\n",
    "        c['dominant_fractions'].to_csv(ANALYSIS_OUTDIR / f'{prefix}_cluster_dominant_fractions.csv', index=False)\n",
    "        out['cluster'] = c\n",
    "    return out\n",
    "\n",
    "_ = summarize_groups(primary, 'primary')\n",
    "\n",
    "if secondary is None:\n",
    "    print('No secondary run selected; skipping cross-run robustness comparison.')\n",
    "else:\n",
    "    _ = summarize_groups(secondary, 'secondary')\n",
    "\n",
    "    if primary['W'].shape[1] != secondary['W'].shape[1]:\n",
    "        print('Primary/secondary K mismatch; skipping archetype-aligned robustness metrics.')\n",
    "    else:\n",
    "        perm, sim = align_archetypes(primary['A_hat'], secondary['A_hat'])\n",
    "        W2 = secondary['W'][:, perm]\n",
    "\n",
    "        t1 = primary['table'].set_index('cell_id')\n",
    "        t2 = secondary['table'].set_index('cell_id')\n",
    "        common = t1.index.intersection(t2.index)\n",
    "        if len(common) == 0:\n",
    "            print('No shared cell IDs between selected runs; skipping per-cell robustness.')\n",
    "        else:\n",
    "            idx1 = np.array([np.where(np.asarray(run_primary['cell_ids']) == c)[0][0] for c in common], dtype=int)\n",
    "            idx2 = np.array([np.where(np.asarray(run_secondary['cell_ids']) == c)[0][0] for c in common], dtype=int)\n",
    "            W1c = primary['W'][idx1]\n",
    "            W2c = W2[idx2]\n",
    "\n",
    "            dom1 = np.argmax(W1c, axis=1)\n",
    "            dom2 = np.argmax(W2c, axis=1)\n",
    "            agree = float((dom1 == dom2).mean())\n",
    "\n",
    "            rho_dom = float(pd.Series(np.max(W1c, axis=1)).corr(pd.Series(np.max(W2c, axis=1)), method='spearman'))\n",
    "            rho_ent = float(pd.Series(-np.sum(W1c * np.log(np.clip(W1c, 1e-8, 1.0)), axis=1)).corr(pd.Series(-np.sum(W2c * np.log(np.clip(W2c, 1e-8, 1.0)), axis=1)), method='spearman'))\n",
    "\n",
    "            robust_df = pd.DataFrame([{\n",
    "                'n_common_cells': int(len(common)),\n",
    "                'dominant_archetype_agreement': agree,\n",
    "                'spearman_top1_weight': rho_dom,\n",
    "                'spearman_entropy': rho_ent,\n",
    "                'mean_archetype_alignment_cosine': float(np.mean([sim[i, perm[i]] for i in range(len(perm))])),\n",
    "            }])\n",
    "            robust_df.to_csv(ANALYSIS_OUTDIR / 'cross_run_robustness_summary.csv', index=False)\n",
    "            display(robust_df)\n",
    "\n",
    "print(f'All outputs written to: {ANALYSIS_OUTDIR}')\n",
    "print('Interpretation notes:')\n",
    "print('- High dominant weight + low entropy + low uncertainty suggest deeper basin occupancy.')\n",
    "print('- High entropy + low margin + high uncertainty/residual norm suggest transition-like zones.')\n",
    "print('- Graph pseudotime is a geodesic ordering in archetype space, not true physical time.')\n"
   ]
