   "source": [
    "# === Graph geodesic pseudotime (kNN in archetype simplex) ===\n",
    "W = primary['W']\n",
    "dom = primary['table']['dominant_archetype'].to_numpy()\n",
    "dom_w = primary['table']['dominant_weight'].to_numpy()\n",
    "\n",
    "root_mask = (dom == int(root_archetype)) & (dom_w >= np.quantile(dom_w[dom == int(root_archetype)], root_quantile) if np.any(dom == int(root_archetype)) else False)\n",
    "if root_mask.sum() == 0:\n",
    "    root_mask = dom == int(root_archetype)\n",
    "\n",
    "if graph_show_progress:\n",
    "    print('Building kNN graph...')\n",
    "keep, graph = build_knn_graph(W, k=graph_k, max_cells=max_cells_for_graph, seed=7, show_progress=graph_show_progress)\n",
    "local_root = np.where(root_mask[keep])[0]\n",
    "if len(local_root) == 0:\n",
    "    local_root = np.array([0], dtype=int)\n",
    "\n",
    "if graph_show_progress:\n",
    "    print('Computing geodesic distances (Dijkstra)...')\n",
    "dist_local = dijkstra_multi_source(graph, local_root.tolist(), show_progress=graph_show_progress)\n",
    "pseudotime = np.full(W.shape[0], np.nan, dtype=np.float64)\n",
    "pseudotime[keep] = dist_local\n",
    "pt = pseudotime.copy()\n",
    "finite = np.isfinite(pt)\n",
    "if finite.any():\n",
    "    pt_min, pt_max = float(np.nanmin(pt[finite])), float(np.nanmax(pt[finite]))\n",
    "    if pt_max > pt_min:\n",
    "        pt[finite] = (pt[finite] - pt_min) / (pt_max - pt_min)\n",
    "\n",
    "primary['table']['graph_pseudotime'] = pt\n",
    "primary['table'].to_csv(ANALYSIS_OUTDIR / 'primary_per_cell_trajectory_metrics.csv', index=False)\n",
    "\n",
    "print(f'Graph cells used: {len(keep)}/{W.shape[0]} | root cells in graph: {len(local_root)}')\n",
    "display(primary['table'][['cell_id','dominant_archetype','dominant_weight','graph_pseudotime']].head())\n",
    "\n",
    "if primary['umap'] is not None:\n",
    "    fig, ax = plt.subplots(figsize=(6, 5))\n",
    "    pt_values = primary['table']['graph_pseudotime'].to_numpy()\n",
    "    pt_vmin, pt_vmax = percentile_limits(pt_values, q_low=color_clip_q_low, q_high=color_clip_q_high)\n",
    "    sc = ax.scatter(primary['umap'][:,0], primary['umap'][:,1], c=pt_values, s=3, cmap='viridis', linewidths=0, vmin=pt_vmin, vmax=pt_vmax)\n",
    "    ax.set_title('UMAP colored by graph pseudotime')\n",
    "    plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)\n",
    "    plt.tight_layout()\n",
    "else:\n",
    "    fig, ax = plt.subplots(figsize=(6, 5))\n",
    "    pt_values = primary['table']['graph_pseudotime'].to_numpy()\n",
    "    pt_vmin, pt_vmax = percentile_limits(pt_values, q_low=color_clip_q_low, q_high=color_clip_q_high)\n",
    "    sc = ax.scatter(primary['pca'][:,0], primary['pca'][:,1], c=pt_values, s=3, cmap='viridis', linewidths=0, vmin=pt_vmin, vmax=pt_vmax)\n",
    "    ax.set_title('PCA colored by graph pseudotime')\n",
    "    plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)\n",
    "    plt.tight_layout()\n"
   ]
  },
