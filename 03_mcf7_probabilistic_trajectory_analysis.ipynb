     "# === Full transition manifold + branch-point inference ===\n",
     "W = primary['W']\n",
     "t = primary['table'].copy()\n",
     "K = W.shape[1]\n",
     "uniform_weight = 1.0 / max(K, 1)\n",
     "active_thr = float(branch_active_weight_threshold_scale) * uniform_weight\n",
     "\n",
     "if 'corr_df' not in globals():\n",
     "    corr_df = corridor_table(\n",
     "        W=W,\n",
     "        entropy=t['entropy'].to_numpy(),\n",
     "        uncertainty=t['uncertainty'].to_numpy(),\n",
     "        residual_norm=t['residual_norm'].to_numpy(),\n",
     "        pair_mass_thr=pair_mass_threshold,\n",
     "        other_mass_thr=other_mass_threshold,\n",
     "        show_progress=False,\n",
     "    )\n",
     "\n",
     "# Cell-level corridor assignment (top-2 archetype pair under corridor thresholds).\n",
     "top2_idx = np.argsort(W, axis=1)[:, -2:]\n",
     "top2_idx = np.sort(top2_idx, axis=1)\n",
     "pair_labels = np.array([f\"A{a}<->A{b}\" for a, b in top2_idx], dtype=object)\n",
     "pair_mass = W[np.arange(W.shape[0]), top2_idx[:, 0]] + W[np.arange(W.shape[0]), top2_idx[:, 1]]\n",
     "other_mass = 1.0 - pair_mass\n",
     "is_corridor = (pair_mass >= pair_mass_threshold) & (other_mass <= other_mass_threshold)\n",
     "pair_label_full = np.where(is_corridor, pair_labels, 'off_corridor')\n",
     "\n",
     "t['corridor_pair'] = pair_label_full\n",
     "t['corridor_pair_mass'] = pair_mass\n",
     "t['active_archetype_count'] = (W > active_thr).sum(axis=1)\n",
     "\n",
     "# Junction score for branch-point candidates (high entropy, many active archetypes, low top1-top2 margin).\n",
     "junction_score_raw = (\n",
     "    zscore_robust(t['entropy'].to_numpy())\n",
     "    + zscore_robust(t['active_archetype_count'].to_numpy())\n",
     "    - zscore_robust(t['top12_margin'].to_numpy())\n",
     ")\n",
     "t['junction_score_raw'] = junction_score_raw\n",
     "j_lo, j_hi = percentile_limits(junction_score_raw, q_low=0.01, q_high=0.99)\n",
     "if j_lo is not None and j_hi is not None:\n",
     "    t['junction_score'] = np.clip(junction_score_raw, j_lo, j_hi)\n",
     "else:\n",
     "    t['junction_score'] = junction_score_raw\n",
     "\n",
     "entropy_vals = t['entropy'].to_numpy()\n",
     "finite_entropy = np.isfinite(entropy_vals)\n",
     "entropy_thr = float(np.quantile(entropy_vals[finite_entropy], branch_entropy_quantile)) if finite_entropy.any() else np.inf\n",
     "junction_vals = t['junction_score'].to_numpy()\n",
     "finite_junction = np.isfinite(junction_vals)\n",
     "junction_thr = float(np.quantile(junction_vals[finite_junction], branch_junction_quantile)) if finite_junction.any() else np.inf\n",
     "\n",
     "t['branch_point_candidate'] = (\n",
     "    (t['active_archetype_count'] >= int(branch_min_active_archetypes))\n",
     "    & (t['entropy'] >= entropy_thr)\n",
     "    & (t['junction_score'] >= junction_thr)\n",
     ")\n",
     "\n",
     "# Archetype-level manifold edges and branch archetype summaries.\n",
     "edge_df = corr_df.loc[corr_df['n_cells'] >= int(branch_min_edge_cells)].copy()\n",
     "edge_df['edge_label'] = edge_df.apply(lambda r: f\"A{int(r['a'])}<->A{int(r['b'])}\", axis=1)\n",
     "\n",
     "degree = np.zeros(K, dtype=int)\n",
     "weighted_degree = np.zeros(K, dtype=float)\n",
     "for _, r in edge_df.iterrows():\n",
     "    a, b, n = int(r['a']), int(r['b']), float(r['n_cells'])\n",
     "    degree[a] += 1\n",
     "    degree[b] += 1\n",
     "    weighted_degree[a] += n\n",
     "    weighted_degree[b] += n\n",
     "\n",
     "branch_archetype_df = pd.DataFrame({\n",
     "    'archetype': [f\"A{k}\" for k in range(K)],\n",
     "    'degree_ge_min_edge': degree,\n",
     "    'weighted_degree': weighted_degree,\n",
     "    'is_branch_archetype': degree >= 3,\n",
     "}).sort_values(['is_branch_archetype', 'weighted_degree'], ascending=[False, False]).reset_index(drop=True)\n",
     "\n",
     "# Save updated manifold/branch outputs.\n",
     "primary['table'] = t\n",
     "primary['table'].to_csv(ANALYSIS_OUTDIR / 'primary_per_cell_trajectory_metrics.csv', index=False)\n",
     "edge_df.to_csv(ANALYSIS_OUTDIR / 'primary_transition_manifold_edges.csv', index=False)\n",
     "branch_archetype_df.to_csv(ANALYSIS_OUTDIR / 'primary_branch_archetype_summary.csv', index=False)\n",
     "t.loc[t['branch_point_candidate']].to_csv(ANALYSIS_OUTDIR / 'primary_branch_point_candidates.csv', index=False)\n",
     "\n",
     "print('Transition manifold summary:')\n",
     "print(f\"  corridor cells: {int((t['corridor_pair'] != 'off_corridor').sum())}/{len(t)}\")\n",
     "print(f\"  manifold edges (n_cells >= {int(branch_min_edge_cells)}): {len(edge_df)}\")\n",
     "print(f\"  branch-point candidate cells: {int(t['branch_point_candidate'].sum())}\")\n",
     "print(f\"  branch archetypes (degree >= 3): {int(branch_archetype_df['is_branch_archetype'].sum())}\")\n",
     "display(edge_df[['edge_label', 'n_cells', 'mean_entropy', 'mean_uncertainty', 'mean_residual_norm']].head(20))\n",
     "display(branch_archetype_df)\n",
     "\n",
     "# Visualization of full manifold assignment and branch-point candidates.\n",
     "coords = primary['umap'] if primary['umap'] is not None else primary['pca']\n",
     "coord_name = 'UMAP' if primary['umap'] is not None else 'PCA'\n",
     "\n",
     "pair_counts = pd.Series(t['corridor_pair']).value_counts()\n",
     "top_pairs = [p for p in pair_counts.index if p != 'off_corridor'][:10]\n",
     "pair_plot = np.where(np.isin(t['corridor_pair'], top_pairs), t['corridor_pair'], np.where(t['corridor_pair'] == 'off_corridor', 'off_corridor', 'other_corridors'))\n",
     "pair_plot = pd.Categorical(pair_plot)\n",
     "pair_codes = pair_plot.codes\n",
     "\n",
     "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
     "sc = axes[0].scatter(coords[:, 0], coords[:, 1], c=pair_codes, s=3, cmap='tab20', linewidths=0)\n",
     "axes[0].set_title(f'{coord_name}: transition manifold pair labels')\n",
     "axes[0].set_xlabel(f'{coord_name}1')\n",
     "axes[0].set_ylabel(f'{coord_name}2')\n",
     "handles = []\n",
     "labels = list(pair_plot.categories)\n",
     "for i, lab in enumerate(labels):\n",
     "    handles.append(plt.Line2D([0], [0], marker='o', color='w', markerfacecolor=plt.cm.tab20(i % 20), markersize=6, label=lab))\n",
     "axes[0].legend(handles=handles, labels=labels, loc='upper right', fontsize=7, frameon=False)\n",
     "\n",
     "axes[1].scatter(coords[:, 0], coords[:, 1], s=3, c='lightgray', linewidths=0, alpha=0.5)\n",
     "bp_mask = t['branch_point_candidate'].to_numpy()\n",
     "axes[1].scatter(coords[bp_mask, 0], coords[bp_mask, 1], s=6, c='red', linewidths=0, alpha=0.8)\n",
     "axes[1].set_title(f'{coord_name}: inferred branch-point candidates')\n",
     "axes[1].set_xlabel(f'{coord_name}1')\n",
     "axes[1].set_ylabel(f'{coord_name}2')\n",
     "plt.tight_layout()\n"
    ]
