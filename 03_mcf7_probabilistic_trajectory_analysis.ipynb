   "source": [
    "# === Corridor analysis + pair-progress pseudotime ===\n",
    "W = primary['W']\n",
    "t = primary['table']\n",
    "corr_df = corridor_table(\n",
    "    W=W,\n",
    "    entropy=t['entropy'].to_numpy(),\n",
    "    uncertainty=t['uncertainty'].to_numpy(),\n",
    "    residual_norm=t['residual_norm'].to_numpy(),\n",
    "    pair_mass_thr=pair_mass_threshold,\n",
    "    other_mass_thr=other_mass_threshold,\n",
    "    show_progress=corridor_show_progress,\n",
    ")\n",
    "corr_df.to_csv(ANALYSIS_OUTDIR / 'primary_corridor_table.csv', index=False)\n",
    "display(corr_df.head(20))\n",
    "corr_nonempty = corr_df.loc[corr_df['n_cells'] > 0].copy()\n",
    "\n",
    "K = W.shape[1]\n",
    "mat = np.zeros((K, K), dtype=float)\n",
    "for _, r in corr_df.iterrows():\n",
    "    a, b = int(r['a']), int(r['b'])\n",
    "    mat[a, b] = r['n_cells']\n",
    "    mat[b, a] = r['n_cells']\n",
    "\n",
    "plt.figure(figsize=(6, 5))\n",
    "mat_vmin, mat_vmax = percentile_limits(mat, q_low=color_clip_q_low, q_high=color_clip_q_high)\n",
    "sns.heatmap(mat, cmap='mako', annot=True, fmt='.0f', vmin=mat_vmin, vmax=mat_vmax)\n",
    "plt.title('Corridor occupancy (coarse transition graph)')\n",
    "plt.xlabel('archetype')\n",
    "plt.ylabel('archetype')\n",
    "plt.tight_layout()\n",
    "\n",
    "if len(corr_nonempty) > 0:\n",
    "    top_pair = corr_nonempty.iloc[0]\n",
    "    a, b = int(top_pair['a']), int(top_pair['b'])\n",
    "    top_mask = corridor_mask_for_pair(W, a=a, b=b, pair_mass_thr=pair_mass_threshold, other_mass_thr=other_mass_threshold)\n",
    "    prog_all = pair_progress(W, a=a, b=b)\n",
    "    prog = prog_all[top_mask]\n",
    "    t['pair_progress_top_corridor'] = np.nan\n",
    "    t.loc[top_mask, 'pair_progress_top_corridor'] = prog\n",
    "    print(f'Top corridor pair: A{a}<->A{b} | corridor cells={int(top_mask.sum())}')\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(14, 4))\n",
    "    sns.histplot(prog, bins=60, ax=axes[0], color='tab:blue'); axes[0].set_title(f'Pair progress A{a}->A{b} (corridor only)')\n",
    "    entropy_vals = t.loc[top_mask, 'entropy'].to_numpy()\n",
    "    axes[1].scatter(prog, entropy_vals, s=3, alpha=0.25)\n",
    "    ent_curve = binned_curve(prog, entropy_vals, n_bins=top_pair_bins, min_count=top_pair_min_bin_count)\n",
    "    if len(ent_curve) > 0:\n",
    "        axes[1].plot(ent_curve['bin_center'], ent_curve['mean'], color='black', lw=2)\n",
    "        axes[1].fill_between(ent_curve['bin_center'], ent_curve['mean'] - ent_curve['sem'], ent_curve['mean'] + ent_curve['sem'], color='black', alpha=0.2)\n",
    "    axes[1].set_xlabel('pair progress'); axes[1].set_ylabel('entropy')\n",
    "    stab_vals = t.loc[top_mask, 'stability_score'].to_numpy()\n",
    "    stab_mask = np.isfinite(stab_vals)\n",
    "    axes[2].scatter(prog[stab_mask], stab_vals[stab_mask], s=3, alpha=0.25)\n",
    "    stab_curve = binned_curve(prog[stab_mask], stab_vals[stab_mask], n_bins=top_pair_bins, min_count=top_pair_min_bin_count)\n",
    "    if len(stab_curve) > 0:\n",
    "        axes[2].plot(stab_curve['bin_center'], stab_curve['mean'], color='black', lw=2)\n",
    "        axes[2].fill_between(stab_curve['bin_center'], stab_curve['mean'] - stab_curve['sem'], stab_curve['mean'] + stab_curve['sem'], color='black', alpha=0.2)\n",
    "    axes[2].set_xlabel('pair progress'); axes[2].set_ylabel('stability')\n",
    "    plt.tight_layout()\n",
    "\n",
    "    primary['table'] = t\n",
    "    primary['table'].to_csv(ANALYSIS_OUTDIR / 'primary_per_cell_trajectory_metrics.csv', index=False)\n",
    "else:\n",
    "    print('No nonempty corridors found under current thresholds; skipping pair-progress plots.')\n",
    "    t['pair_progress_top_corridor'] = np.nan\n",
    "    primary['table'] = t\n",
    "    primary['table'].to_csv(ANALYSIS_OUTDIR / 'primary_per_cell_trajectory_metrics.csv', index=False)\n"
   ]
  },
