   "source": [
    "# === Discover/select runs ===\n",
    "runs_df = discover_runs(SWEEP_ROOT_CANDIDATES)\n",
    "if runs_df.empty:\n",
    "    raise FileNotFoundError(\"No completed run directories found under configured sweep roots.\")\n",
    "\n",
    "raw_runs_path = ANALYSIS_OUTDIR / \"available_runs_snapshot.csv\"\n",
    "runs_df.to_csv(raw_runs_path, index=False)\n",
    "\n",
    "cand = runs_df.copy()\n",
    "selection_log = []\n",
    "selection_log.append((\"all discovered\", len(cand)))\n",
    "\n",
    "if selected_model_type is not None:\n",
    "    cand = cand.loc[cand[\"model_type\"].astype(str).str.lower() == str(selected_model_type).lower()].copy()\n",
    "selection_log.append((f\"model_type={selected_model_type}\", len(cand)))\n",
    "\n",
    "if selected_decoder_type is not None:\n",
    "    cand = cand.loc[cand[\"decoder_type\"].astype(str).str.lower() == str(selected_decoder_type).lower()].copy()\n",
    "selection_log.append((f\"decoder_type={selected_decoder_type}\", len(cand)))\n",
    "\n",
    "k_values = _to_k_list(selected_k)\n",
    "if k_values is not None:\n",
    "    cand = cand.loc[cand[\"K\"].isin(k_values)].copy()\n",
    "selection_log.append((f\"selected_k={k_values}\", len(cand)))\n",
    "\n",
    "if require_no_dead_archetypes:\n",
    "    cand = cand.loc[cand[\"dead_archetypes\"].fillna(np.inf) <= dead_archetype_threshold].copy()\n",
    "selection_log.append((f\"dead_archetypes<={dead_archetype_threshold}\", len(cand)))\n",
    "\n",
    "if cand.empty:\n",
    "    avail_k = sorted(runs_df['K'].dropna().unique().tolist())\n",
    "    raise ValueError(f\"No runs match current filters. Available K values: {avail_k}\")\n",
    "\n",
    "if run_selection_metric not in cand.columns:\n",
    "    raise ValueError(f\"Invalid run_selection_metric={run_selection_metric}.\")\n",
    "cand = cand.sort_values(run_selection_metric, ascending=True).reset_index(drop=True)\n",
    "\n",
    "if RUN_DIR is not None:\n",
    "    selected = cand.loc[cand['run_dir'] == str(Path(RUN_DIR).resolve())].copy()\n",
    "elif RUN_ID is not None:\n",
    "    selected = cand.loc[cand['run_id'].astype(str) == str(RUN_ID)].copy()\n",
    "else:\n",
    "    selected = cand.head(max(1, int(n_runs_for_robustness))).copy()\n",
    "\n",
    "if selected.empty:\n",
    "    raise ValueError(\"RUN_DIR/RUN_ID override did not match filtered candidates.\")\n",
    "\n",
    "filtered_path = ANALYSIS_OUTDIR / \"filtered_runs_snapshot.csv\"\n",
    "selected_path = ANALYSIS_OUTDIR / \"selected_runs.csv\"\n",
    "cfg_path = ANALYSIS_OUTDIR / \"selection_config.json\"\n",
    "cand.to_csv(filtered_path, index=False)\n",
    "selected.to_csv(selected_path, index=False)\n",
    "cfg_path.write_text(json.dumps({\n",
    "    'selected_k': k_values,\n",
    "    'selected_model_type': selected_model_type,\n",
    "    'selected_decoder_type': selected_decoder_type,\n",
    "    'run_selection_metric': run_selection_metric,\n",
    "    'n_runs_for_robustness': int(n_runs_for_robustness),\n",
    "}, indent=2), encoding='utf-8')\n",
    "\n",
    "print(\"Selection report:\")\n",
    "for k, n in selection_log:\n",
    "    print(f\"  {k}: {n}\")\n",
    "print(f\"Saved run snapshots to: {ANALYSIS_OUTDIR}\")\n",
    "display(selected[['run_id','K','decoder_type','val_recon','dead_archetypes','usage_std','mean_entropy','purity_gt_08','run_dir']])\n",
    "\n",
    "run_primary = load_run_outputs(Path(selected.iloc[0]['run_dir']))\n",
    "run_secondary = load_run_outputs(Path(selected.iloc[1]['run_dir'])) if len(selected) > 1 else None\n",
    "print(f\"Primary run: {selected.iloc[0]['run_id']}\")\n",
    "if run_secondary is not None:\n",
    "    print(f\"Secondary run: {selected.iloc[1]['run_id']}\")\n"
   ]
